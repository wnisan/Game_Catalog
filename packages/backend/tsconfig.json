{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": false,
    "composite": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": [
      "node"
    ],
    "allowJs": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "paths": {
      "@game-catalog/shared": [
        "../shared/src/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../shared"
    }
  ],
  "include": [
    "**/*.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "scripts"
  ]
}