{
  "name": "game-catalog-monorepo",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -A -ptv --include @game-catalog/backend --include @game-catalog/frontend run dev",
    "typecheck": "yarn workspace @game-catalog/shared build && yarn workspace @game-catalog/shared typecheck && yarn workspaces foreach -A -ptv --exclude @game-catalog/shared run typecheck",
    "lint": "yarn workspaces foreach -A -ptv run lint",
    "build": "yarn workspaces foreach -A -ptv --include @game-catalog/shared --include @game-catalog/backend --include @game-catalog/frontend run build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
